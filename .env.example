# 复制为 .env 后填写本地真实值（.env 已被 gitignore，不会提交）
# cp .env.example .env

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_mysql_password
DB_DATABASE=anime_chat

# JWT 签名密钥（生产务必换成足够长的随机串）
JWT_SECRET=change-me-to-a-long-random-string

# MinIO 对象存储（Private 桶；后端用 Access Key 访问）
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=anime-chat
MINIO_AVATAR_PREFIX=avatars
MINIO_PLAYBACK_PREFIX=playback

# qBittorrent Web API（Docker：docker compose -f docker-compose.playback.yml up -d）
# 云服务器与 Nest 同机容器即可，无需 apt 安装桌面版
QB_ENABLED=true
QB_URL=http://127.0.0.1:8085
QB_USERNAME=admin
QB_PASSWORD=adminadmin
# Nest 读取已下载文件的路径：需与 qB 容器 /downloads 挂载到宿主机的目录一致
QB_DOWNLOAD_PATH=./data/bt-downloads

# 播放会话（边下边播阈值）
PLAYBACK_PLAYABLE_PROGRESS=0.15
PLAYBACK_PLAYABLE_MIN_BYTES=31457280
PLAYBACK_POLL_INTERVAL_MS=3000
# 下完是否再拷到 MinIO（同机建议 false：直接播 qB 目录，避免双份盘）
PLAYBACK_UPLOAD_TO_MINIO=false
